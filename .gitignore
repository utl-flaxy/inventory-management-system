```gitignore
# ==========================================
# Spring Boot
# ==========================================

HELP.md

target/
!**/src/main/**/target/
!**/src/test/**/target/

.mvn/wrapper/maven-wrapper.jar


# ==========================================
# STS
# ==========================================

.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache


# ==========================================
# IntelliJ IDEA
# ==========================================

.idea/
*.iws
*.iml
*.ipr


# ==========================================
# VS Code
# ==========================================

.vscode/


# ==========================================
# NetBeans
# ==========================================

/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

build/
!**/src/main/**/build/
!**/src/test/**/build/


# ==========================================
# Logs
# ==========================================

*.log
log.txt


# ==========================================
# Database
# ==========================================

# H2
data/

# MariaDB volume
mariadb_data/


# ==========================================
# Terraform
# ==========================================

terraform/.terraform/

terraform/*.tfstate
terraform/*.tfstate.*

terraform/terraform.tfvars

terraform/.terraform.lock.hcl


# ==========================================
# Environment variables
# ==========================================

.env
.env.*

application-local.properties


# ==========================================
# OS
# ==========================================

.DS_Store
Thumbs.db


# ==========================================
# Generated files
# ==========================================

*.class
*.jar
*.war
*.ear


# ==========================================
# Temporary files
# ==========================================

*.tmp
*.bak
*.swp


# ==========================================
# Maven Wrapper logs
# ==========================================

.mvn/timing.properties


# ==========================================
# AWS
# ==========================================

*.pem


# ==========================================
# Docker
# ==========================================

docker-compose.override.yml


# ==========================================
# Test Reports
# ==========================================

surefire-reports/
failsafe-reports/


# ==========================================
# Mac
# ==========================================

.AppleDouble
.LSOverride


# ==========================================
# Windows
# ==========================================

Desktop.ini


# ==========================================
# Ignore Terraform Provider Cache
# ==========================================

**/.terraform/*
```
